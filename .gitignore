# Old mobile features
old_phone = {
    "Display": "LCD",
    "Camera": "12MP",
    "Battery": "4000mAh",
    "Charging": "Normal Charging",
    "Network": "4G"
}

# New mobile features
new_phone = {
    "Display": "AMOLED",
    "Camera": "50MP",
    "Battery": "5000mAh",
    "Charging": "Fast Charging",
    "Network": "5G",
    "Fingerprint": "In-display",
    "Face Unlock": "Yes"
}

print("New Features in the Mobile Phone:\n")

# Finding new or upgraded features
for feature in new_phone:
    if feature not in old_phone:
        print(f"{feature} → New Feature Added")
    elif new_phone[feature] != old_phone[feature]:
        print(f"{feature} → Upgraded from {old_phone[feature]} to {new_phone[feature]}")
